{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/edithatogo/fyi-archive/schema/foi-o-derived-manifest.schema.json",
  "title": "FOI-O derived extraction manifest",
  "type": "object",
  "required": ["conforms_to", "contract_id", "version", "release_status", "ontology", "profile", "codebook", "candidate_status", "provenance"],
  "properties": {
    "conforms_to": {"const": "foi-o-extraction-contract/0.1.0"},
    "contract_id": {"const": "foi-o-extraction"},
    "version": {"type": "string", "minLength": 1},
    "release_status": {"enum": ["draft", "verified"]},
    "candidate_status": {"const": "candidate"},
    "ontology": {"$ref": "#/$defs/versioned_digest"},
    "profile": {"$ref": "#/$defs/versioned_digest"},
    "codebook": {"$ref": "#/$defs/versioned_digest"},
    "provenance": {
      "type": "object",
      "required": ["source_repository", "source_revision", "source_digest", "extraction_run_id", "pipeline_id", "pipeline_version", "generated_at"],
      "properties": {
        "source_repository": {"type": "string", "minLength": 1},
        "source_revision": {"type": "string", "minLength": 7, "not": {"enum": ["main", "latest", "HEAD"]}},
        "source_digest": {"$ref": "#/$defs/digest"},
        "extraction_run_id": {"type": "string", "minLength": 1},
        "pipeline_id": {"type": "string", "minLength": 1},
        "pipeline_version": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "versioned_digest": {
      "type": "object",
      "required": ["id", "version", "sha256"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/digest"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
