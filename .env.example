# Copy to .env and fill in. Never commit .env.
# All values are also expected as GitHub Actions secrets/variables (see README).

# ---- Hugging Face ----
# A write-enabled token from https://huggingface.co/settings/tokens
HF_TOKEN=
HF_REPO_ID=edithatogo/fyi-archive-nz

# ---- Zenodo ----
# Production token from https://zenodo.org/account/settings/applications/tokens/
ZENODO_TOKEN=
# Sandbox token for draft rehearsal: https://sandbox.zenodo.org/account/settings/applications/
ZENODO_SANDBOX_TOKEN=

# ---- OSF ----
# Personal access token from https://osf.io/settings/tokens
OSF_TOKEN=
OSF_PARENT_ID=
OSF_USERNAME=
OSF_PASSWORD=

# ---- GitHub (for gh CLI + mirror push; GITHUB_TOKEN is auto-provided in Actions) ----
GITHUB_TOKEN=

# ---- fyi-archive tuning (optional; sensible defaults are baked in) ----
# Archive instance id (nz-fyi default; au-rtk for Right to Know Australia).
FYI_ARCHIVE_INSTANCE=nz-fyi
# Base site being archived (override; must match instance when set).
FYI_ARCHIVE_BASE_URL=https://fyi.org.nz
# Politeness: minimum seconds between requests to the same host.
# Honour fyi-cli shared rate limits; do not raise without evidence.
FYI_ARCHIVE_MIN_INTERVAL=1.0
# Max concurrent in-flight requests to the site.
FYI_ARCHIVE_CONCURRENCY=2
# Descriptive User-Agent suffix incl. contact (sent with every request).
FYI_ARCHIVE_CONTACT=mailto:edithatogo@users.noreply.github.com
